    {
      "start": 276.7,
      "end": 288.6,
      "line_idx": 7,
      "verse_id": 42923,
      "banidb_gurmukhi": "ਕਰਨ ਕਾਰਨ ਸਮਰਥੁ ਸੁਆਮੀ ਨਾਨਕੁ ਤਿਸੁ ਕੁਰਬਾਨੁ ਹੇ ॥੫॥੨॥੩੨॥",
      "banidb_larivaar": "ਕਰਨਕਾਰਨਸਮਰਥੁਸੁਆਮੀਨਾਨਕੁਤਿਸੁਕੁਰਬਾਨੁਹੇ॥੫॥੨॥੩੨॥",
      "shabad_id": 3712
    }
  ],
  "lines": [
    {
      "line_idx": 0,
      "text": "ਮਾਰੂ ਮਹਲਾ ੫ ॥",
      "shabad_id": 3712
    },
    {
      "line_idx": 1,
      "text": "ਵੈਦੋ ਨ ਵਾਈ ਭੈਣੋ ਨ ਭਾਈ ਏਕੋ ਸਹਾਈ ਰਾਮੁ ਹੇ ॥੧॥",
      "shabad_id": 3712
    },
    {
      "line_idx": 2,
      "text": "ਕੀਤਾ ਜਿਸੋ ਹੋਵੈ ਪਾਪਾਂ ਮਲੋ ਧੋਵੈ ਸੋ ਸਿਮਰਹੁ ਪਰਧਾਨੁ ਹੇ ॥੨॥",
      "shabad_id": 3712
    },
    {
      "line_idx": 3,
      "text": "ਘਟਿ ਘਟੇ ਵਾਸੀ ਸਰਬ ਨਿਵਾਸੀ ਅਸਥਿਰੁ ਜਾ ਕਾ ਥਾਨੁ ਹੇ ॥੩॥",
      "shabad_id": 3712
    },
    {
      "line_idx": 4,
      "text": "ਆਵੈ ਨ ਜਾਵੈ ਸੰਗੇ ਸਮਾਵੈ ਪੂਰਨ ਜਾ ਕਾ ਕਾਮੁ ਹੇ ॥੪॥",
      "shabad_id": 3712
    },
    {
      "line_idx": 5,
      "text": "ਭਗਤ ਜਨਾ ਕਾ ਰਾਖਣਹਾਰਾ ॥",
      "shabad_id": 3712
    },
    {
      "line_idx": 6,
      "text": "ਸੰਤ ਜੀਵਹਿ ਜਪਿ ਪ੍ਰਾਨ ਅਧਾਰਾ ॥",
      "shabad_id": 3712
    },
    {
      "line_idx": 7,
      "text": "ਕਰਨ ਕਾਰਨ ਸਮਰਥੁ ਸੁਆਮੀ ਨਾਨਕੁ ਤਿਸੁ ਕੁਰਬਾਨੁ ਹੇ ॥੫॥੨॥੩੨॥",
      "shabad_id": 3712
    }
  ],
