  "segments": [
    {
      "start": 0,
      "end": 67.1,
      "line_idx": 1,
      "verse_id": 42917,
      "banidb_gurmukhi": "ਵੈਦੋ ਨ ਵਾਈ ਭੈਣੋ ਨ ਭਾਈ ਏਕੋ ਸਹਾਈ ਰਾਮੁ ਹੇ ॥੧॥",
      "banidb_larivaar": "ਵੈਦੋਨਵਾਈਭੈਣੋਨਭਾਈਏਕੋਸਹਾਈਰਾਮੁਹੇ॥੧॥"
    },
    {
      "start": 69.5,
      "end": 107.7,
      "line_idx": 2,
      "verse_id": 42918,
      "banidb_gurmukhi": "ਕੀਤਾ ਜਿਸੋ ਹੋਵੈ ਪਾਪਾਂ ਮਲੋ ਧੋਵੈ ਸੋ ਸਿਮਰਹੁ ਪਰਧਾਨੁ ਹੇ ॥੨॥",
      "banidb_larivaar": "ਕੀਤਾਜਿਸੋਹੋਵੈਪਾਪਾਂਮਲੋਧੋਵੈਸੋਸਿਮਰਹੁਪਰਧਾਨੁਹੇ॥੨॥"
    },
    {
      "start": 112.5,
      "end": 148.9,
      "line_idx": 3,
      "verse_id": 42919,
      "banidb_gurmukhi": "ਘਟਿ ਘਟੇ ਵਾਸੀ ਸਰਬ ਨਿਵਾਸੀ ਅਸਥਿਰੁ ਜਾ ਕਾ ਥਾਨੁ ਹੇ ॥੩॥",
      "banidb_larivaar": "ਘਟਿਘਟੇਵਾਸੀਸਰਬਨਿਵਾਸੀਅਸਥਿਰੁਜਾਕਾਥਾਨੁਹੇ॥੩॥"
    },
    {
      "start": 154.5,
      "end": 179.3,
      "line_idx": 4,
      "verse_id": 42920,
      "banidb_gurmukhi": "ਆਵੈ ਨ ਜਾਵੈ ਸੰਗੇ ਸਮਾਵੈ ਪੂਰਨ ਜਾ ਕਾ ਕਾਮੁ ਹੇ ॥੪॥",
      "banidb_larivaar": "ਆਵੈਨਜਾਵੈਸੰਗੇਸਮਾਵੈਪੂਰਨਜਾਕਾਕਾਮੁਹੇ॥੪॥"
    },
    {
      "start": 180.7,
      "end": 204.7,
      "line_idx": 5,
      "verse_id": 42921,
      "banidb_gurmukhi": "ਭਗਤ ਜਨਾ ਕਾ ਰਾਖਣਹਾਰਾ ॥",
      "banidb_larivaar": "ਭਗਤਜਨਾਕਾਰਾਖਣਹਾਰਾ॥"
    },
    {
      "start": 205.6,
      "end": 220.9,
      "line_idx": 6,
      "verse_id": 42922,
      "banidb_gurmukhi": "ਸੰਤ ਜੀਵਹਿ ਜਪਿ ਪ੍ਰਾਨ ਅਧਾਰਾ ॥",
      "banidb_larivaar": "ਸੰਤਜੀਵਹਿਜਪਿਪ੍ਰਾਨਅਧਾਰਾ॥"
    },
    {
      "start": 221.4,
      "end": 228,
      "line_idx": 5,
      "verse_id": 42921,
      "banidb_gurmukhi": "ਭਗਤ ਜਨਾ ਕਾ ਰਾਖਣਹਾਰਾ ॥",
      "banidb_larivaar": "ਭਗਤਜਨਾਕਾਰਾਖਣਹਾਰਾ॥"
    },
